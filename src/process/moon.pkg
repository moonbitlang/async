import {
  "moonbitlang/async/internal/event_loop",
  "moonbitlang/async/internal/coroutine",
  "moonbitlang/async/internal/fd_util",
  "moonbitlang/async/internal/os_string",
  "moonbitlang/async/internal/c_buffer",
  "moonbitlang/async/pipe",
  "moonbitlang/async/stdio",
  "moonbitlang/async",
  "moonbitlang/async/io",
  "moonbitlang/async/fs",
  "moonbitlang/async/signal",
  "moonbitlang/async/os_error",
  "moonbitlang/core/encoding/utf8",
}

import {
  "moonbitlang/core/env",
  "moonbitlang/core/string",
  "moonbitlang/async/fs",
  "moonbitlang/async/internal/test_util",
} for "test"

options(
  "max-concurrent-tests": 5,
  "native-stub": [ "unix.c", "windows.c" ],
  targets: {
    "process.mbt": [ "native", "wasm" ],
    "unix.mbt": [ "native", "wasm" ],
    "windows.mbt": [ "native", "wasm" ],
    "wasm.mbt": [ "wasm" ],
    "basic_test.mbt": [ "native", "wasm" ],
    "cancel_test.mbt": [ "native", "wasm" ],
    "cancellation.mbt": [ "native", "wasm" ],
    "commands_for_test.mbt": [ "native", "wasm" ],
    "cwd_test.mbt": [ "native", "wasm" ],
    "env_test.mbt": [ "native", "wasm" ],
    "helper_test.mbt": [ "native", "wasm" ],
    "redirect.mbt": [ "native", "wasm" ],
    "redirect_test.mbt": [ "native", "wasm" ],
    "spawn_in_group_test.mbt": [ "native", "wasm" ],
    "wait_test.mbt": [ "native", "wasm" ],
  },
)
