///|
/// File system event generated by `@fs.Watcher`.
///
/// - `Create(path)`: a new file is created at `path`
///
/// - `Remove(path)`: the file at `path` is removed
///
/// - `Rename(old~, new~)`: the file at `old` is moved to location `new`.
///    Note that only rename operation within the watched tree will be reported as `Rename`.
///    Moving a file out of the watched tree will result in a `Remove` event,
///    while moving a file into the watched tree will result in a `Create` event.
///
///    Note that rename detection is inherently racy due to OS limitations,
///    and is only best-effort. Although rare, it is still possible for a rename operation
///    to appear as separated `Remove` + `Create` operations.
///
/// - `Modify(path)`: the file at `path` is modified
///
/// - `Overflow`: too many file system events are generated and cannot be processed.
///    the user should assume all content in the watched directory may have changed
///    upon receiving this event.
///
///    The watcher will still automatically rescan the directory,
///    and ensure that at least `Create`/`Remove`/`Rename` events are properly reported,
///    in a way that can rebuild the current state of the watched directory.
///
/// Here are some special cases:
///
/// - if a rename operation replaces an existing file,
///   a `Remove` event will be reported on that location first,
///   before the actual event for the rename operation itself
///
/// - When a directory is moved into/out of the watched tree,
///   no event will be generated for files inside that directory.
///   Similarly for rename operations.
///
/// - when modifying a file with multiple hard links within the watched tree,
///   the behavior is currently undefined. It is only guaranteed that a `Modify` event
///   will be generated on at least one of the hard liks.
pub(all) enum FsEvent {
  Create(String)
  Remove(String)
  Rename(old~ : String, new~ : String)
  Modify(String)
  Overflow
} derive(Eq, Hash, Debug)

///|
#valtype
priv struct FileIdentity {
  dev_id : UInt64
  file_id : UInt64
} derive(Eq, Hash)

///|
priv struct WatchedFile {
  fd : @fd_util.Fd
  paths : Set[String]
  kind : @fd_util.FileKind
  children : Map[String, FileIdentity]
}

///|
priv struct PendingChange {
  link : Array[(FileIdentity, String)]
  unlink : Array[(FileIdentity, String)]
  mut modified : Bool
}

///|
priv trait WatcherBackend {
  close(Self) -> Unit
  async wait(Self) -> Unit
}

///|
struct Watcher {
  mut backend : &WatcherBackend?
  root : WatchedFile
  /// The status of `watched` is the status the user has currently retrieved.
  /// Assume `pending` is up-to-date, applying `pending` on `watched`
  /// should result in the current state of the watched tree
  watched : Map[FileIdentity, WatchedFile]
  pending : Map[FileIdentity, PendingChange]
}

///|
fn[X : Eq + Hash] Set::pop(self : Set[X]) -> X? {
  let result = self.iter().next()
  if result is Some(elem) {
    self.remove(elem)
  }
  result
}

///|
fn WatchedFile::child_path(self : WatchedFile, name : String) -> String {
  guard self.paths.iter().next() is Some(path)
  if path is "" {
    name
  } else {
    "\{path}/\{name}"
  }
}

///|
pub async fn Watcher::wait(self : Watcher) -> Array[FsEvent] {
  ...
  let events = []
  while self.pending.keys().next() is Some(id) {
    self.emit_changes_for(id, into=events)
  }
  events
}

///|
fn Watcher::emit_changes_for(
  self : Watcher,
  id : FileIdentity,
  into~ : Array[FsEvent],
) -> Unit {
  guard self.pending.get(id) is Some(changes) else { return }
  self.pending.remove(id)
  let file = self.watched[id]
  if file.kind is Directory {
    for child_id in file.children.values() {
      self.emit_changes_for(child_id, into~)
    }
  }
  for link = changes.link[:], unlink = changes.unlink[:] {
    match (link, unlink) {
      ([], []) => break
      ([(dir, name), .. link], []) => {
        let dir = self.watched[dir]
        let path = dir.child_path(name)
        if dir.children.get(name) is Some(existing) {
          self.emit_changes_for(existing, into~)
        }
        into.push(Create(path))
        dir.children[name] = id
        file.paths.add(path)
        continue link, unlink
      }
      ([], [(dir, name), .. unlink]) => {
        let dir = self.watched[dir]
        let path = dir.child_path(name)
        into.push(Remove(path))
        dir.children.remove(name)
        file.paths.remove(path)
        continue link, unlink
      }
      ([(dst, dst_name), .. link], [(src, src_name), .. unlink]) => {
        let src = self.watched[src]
        let dst = self.watched[dst]
        let old = src.child_path(src_name)
        let new = dst.child_path(dst_name)
        into.push(Remove(old))
        src.children.remove(src_name)
        file.paths.remove(old)
        let curr_len = into.length()
        if dst.children.get(dst_name) is Some(existing) {
          self.emit_changes_for(existing, into~)
        }
        if curr_len == into.length() {
          let _ = into.pop()
          into.push(Rename(old~, new~))
        } else {
          into.push(Create(new))
        }
        dst.children[dst_name] = id
        file.paths.add(new)
        continue link, unlink
      }
    }
  }
  if changes.modified {
    for path in file.paths {
      into.push(Modify(path))
    }
  }
  if file.paths.is_empty() {
    self.watched.remove(id)
  }
}

///|
fn Watcher::get_changes_for(self : Watcher, id : FileIdentity) -> PendingChange {
  if self.pending.get(id) is Some(changes) {
    return changes
  }
  let changes = { link: [], unlink: [], modified: false }
  self.pending[id] = changes
  changes
}
