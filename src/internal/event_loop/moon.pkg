    "event_bus.wasm.mbt": [ "wasm" ],
    "process_unix.mbt": [ "native" ],
    "process_windows.mbt": [ "native" ],
    "signal.mbt": [ "native" ],
    "stdio.mbt": [ "native" ],
    "thread_pool.mbt": [ "native" ],
    "timer.mbt": [ "native", "wasm" ],
    "event_loop.wasm.mbt": [ "wasm" ],
    "io.wasm.mbt": [ "wasm" ],
    "unimplemented.mbt": [ "wasm-gc" ],
